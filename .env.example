# ============================================
# SAPURI SYSTEM - Variáveis de Ambiente
# ============================================
# Copie este arquivo para .env e configure os valores
# cp .env.example .env

# ============================================
# 🗄️ DATABASE (Obrigatório)
# ============================================

# URL de conexão do PostgreSQL
# Formato: postgresql://usuario:senha@host:porta/database
# Exemplo local: postgresql://postgres:password@localhost:5432/sapuri
# Railway gera automaticamente esta URL
DATABASE_URL=postgresql://usuario:senha@localhost:5432/sapuri

# ============================================
# 🔐 SEGURANÇA (Obrigatório)
# ============================================

# Chave secreta para sessões (gere uma string aleatória)
# Exemplo: openssl rand -base64 32
SESSION_SECRET=sua-chave-secreta-aqui

# ============================================
# 🌐 SERVIDOR
# ============================================

# Porta do servidor (Railway define automaticamente)
PORT=5000

# Ambiente de execução
# development = modo desenvolvimento com hot reload
# production = modo produção otimizado
NODE_ENV=development

# ID do owner/admin (opcional)
# Permite acesso admin sem autenticação
OWNER_OPEN_ID=admin

# ============================================
# 🤖 TELEGRAM BOT - Principal
# ============================================

# Token do bot Telegram (obtido via @BotFather)
# 1. Fale com @BotFather no Telegram
# 2. Use /newbot para criar
# 3. Copie o token gerado
TELEGRAM_BOT_TOKEN=

# ID do grupo Telegram para notificações
# Use número negativo para grupos
# Exemplo: -1001234567890
TELEGRAM_GROUP_ID=

# ============================================
# 💰 PAINEL DE CONTAS - Telegram
# ============================================

# Token do bot para o painel de contas
# Pode ser o mesmo bot ou um bot diferente
PAINEL_CONTAS_BOT_TOKEN=

# Chat ID para enviar notificações de contas
# Pode ser grupo ou chat privado
PAINEL_CONTAS_CHAT_ID=

# ============================================
# 🧠 LLM / IA (Opcional)
# ============================================

# API Key do serviço de LLM
# Usado para o chat com IA
LLM_API_KEY=

# URL da API do LLM
LLM_API_URL=

# ============================================
# 📱 WHATSAPP (Configuração via interface)
# ============================================

# WhatsApp é configurado via QR Code na interface
# Não requer variáveis de ambiente
# A sessão é salva em: server/whatsapp-sessions/

# ============================================
# 🚂 RAILWAY - Variáveis Especiais
# ============================================

# O Railway define automaticamente:
# - DATABASE_URL (se PostgreSQL adicionado)
# - PORT (dinâmico)
# - RAILWAY_STATIC_URL (URL pública)

# Opcional: Customizar comandos de build
# NIXPACKS_BUILD_CMD=pnpm build
# NIXPACKS_START_CMD=pnpm start
